# این فایل را به wrangler.toml تغییر نام بده و مقادیر را پر کن.
name = "afsaneha-bot"
main = "worker.js"
compatibility_date = "2024-11-01"

[vars]
GH_OWNER = "YOUR_GITHUB_USERNAME"     # صاحب مخزن
GH_REPO  = "afsaneha"                 # نام مخزن
GH_BASE  = "main"                     # شاخه‌ی اصلی
ALLOWED_ORIGIN = "https://YOUR_GITHUB_USERNAME.github.io"

# Secrets (در ریپو ذخیره نکن! با دستور زیر تنظیم کن):
#   npx wrangler secret put GITHUB_TOKEN
#   npx wrangler secret put TURNSTILE_SECRET
